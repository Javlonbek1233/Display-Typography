{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User custom settings, fantasy team, and current balance/points.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "username": { "type": "string" },
        "fantasyTeamName": { "type": "string" },
        "points": { "type": "integer" },
        "credits": { "type": "integer" },
        "roster": {
          "type": "array",
          "description": "List of player IDs in the user's fantasy team"
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "username", "points", "credits"]
    },
    "SportMatch": {
      "title": "Futuristic Sport Match",
      "description": "Details of an active, upcoming, or finished cyberpunk sport match.",
      "type": "object",
      "properties": {
        "matchId": { "type": "string" },
        "sport": { "type": "string" },
        "teamHome": { "type": "string" },
        "teamAway": { "type": "string" },
        "teamHomeLogo": { "type": "string" },
        "teamAwayLogo": { "type": "string" },
        "scoreHome": { "type": "integer" },
        "scoreAway": { "type": "integer" },
        "status": { "type": "string" },
        "minute": { "type": "integer" },
        "spectators": { "type": "integer" },
        "stats": { "type": "object" },
        "description": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["matchId", "sport", "teamHome", "teamAway", "scoreHome", "scoreAway", "status"]
    },
    "LeaderboardTeam": {
      "title": "Leaderboard Team",
      "description": "Ranking stats of futuristic sports leagues.",
      "type": "object",
      "properties": {
        "teamId": { "type": "string" },
        "name": { "type": "string" },
        "logo": { "type": "string" },
        "played": { "type": "integer" },
        "won": { "type": "integer" },
        "drawn": { "type": "integer" },
        "lost": { "type": "integer" },
        "points": { "type": "integer" },
        "hyperIndex": { "type": "number" }
      },
      "required": ["teamId", "name", "points"]
    },
    "AiPrediction": {
      "title": "AI Prediction Analysis",
      "description": "AI analysis and prediction for matches generated by Gemini API.",
      "type": "object",
      "properties": {
        "matchId": { "type": "string" },
        "predictedWinner": { "type": "string" },
        "confidenceHex": { "type": "string" },
        "confidence": { "type": "integer" },
        "winProbability": { "type": "object" },
        "analystReport": { "type": "string" },
        "simulatedTimeline": { "type": "array" },
        "generatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["matchId", "predictedWinner", "confidence", "analystReport"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Store user profiles."
    },
    "/matches/{matchId}": {
      "schema": "SportMatch",
      "description": "Futuristic match documents."
    },
    "/leaderboards/{teamId}": {
      "schema": "LeaderboardTeam",
      "description": "League overall standing teams."
    },
    "/predictions/{matchId}": {
      "schema": "AiPrediction",
      "description": "AI-generated strategy and prediction analytics."
    }
  }
}
